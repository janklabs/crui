# Container Registry URL (required)
REGISTRY_URL="https://registry.example.com"

# Optional: override the registry URL shown in the UI
# Useful when the server-side URL differs from what users see (e.g., Docker networking)
DISPLAY_REGISTRY_URL=""

# Optional: default credentials for the registry
# If not set and the registry requires auth, users will be prompted to log in
REGISTRY_USERNAME=""
REGISTRY_PASSWORD=""

# Session encryption secret (required, at least 32 characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-random-string-at-least-32-chars-long"
